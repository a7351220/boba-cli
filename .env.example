# boba-cli 環境變數設定
# 複製為 .env 並填入實際值：cp .env.example .env

# ── 新聞 API（來自 6551.io）──────────────────────────────────
# BlockBeats 快訊 API
BLOCKBEATS_API_KEY=

# OpenNews + Twitter 共用同一個 JWT token（6551.io 申請）
OPENNEWS_TOKEN=
TWITTER_TOKEN=

# ── Telegram ────────────────────────────────────────────────
# Bot token（從 @BotFather 取得）
# 測試頻道：@test3635 / 正式頻道：@bobadaoann
TELEGRAM_BOT_TOKEN=

# ── AI 生圖 ─────────────────────────────────────────────────
# Google Gemini Flash（用於 generate-daily-image.sh）
GEMINI_API_KEY=
